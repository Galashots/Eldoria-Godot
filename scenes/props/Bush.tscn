[gd_scene format=3]

; Placeholder depth prop (bootstrap-polygon art, matching StandingStone/LoneTree).
; Purely visual: no collision, no script. A small rounded clump, low silhouette so it
; reads as undergrowth rather than a landmark. Authored from the node origin (base at
; y~0) upward so y_sort uses the base as the sort key, like the other props.

[node name="Bush" type="Node2D"]
y_sort_enabled = true

[node name="Clump" type="Polygon2D" parent="."]
polygon = PackedVector2Array(-18, 0, -20, -14, -12, -24, 0, -28, 12, -24, 20, -14, 18, 0)
color = Color(0.22, 0.5, 0.24, 1)

[node name="Highlight" type="Polygon2D" parent="."]
polygon = PackedVector2Array(-8, -14, 2, -22, 10, -16, 4, -8, -6, -8)
color = Color(0.32, 0.62, 0.32, 1)
